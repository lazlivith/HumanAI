# ===========================
# HUMAI — Environment Variables
# ===========================

# URL de base de l'API backend (sans slash final)
VITE_API_URL=http://localhost:3000/api

# Environnement : development | staging | production
VITE_APP_ENV=development

# DSN Sentry pour le monitoring des erreurs (laisser vide en développement)
VITE_SENTRY_DSN=

# Nom de l'application (utilisé dans les traces Sentry)
VITE_APP_NAME=HUMAI HR Platform
